---
// Coherent line-icon set, 1.6 stroke, round caps. Decorative by default
// (aria-hidden); pass a `title` to expose an accessible label.
const { name, size = 24, title, color, class: className = "" } = Astro.props;

const paths = {
  wave: '<path d="M3 12c2.2 0 2.2-3 4.5-3S9.7 12 12 12s2.2-3 4.5-3S18.8 12 21 12"/><path d="M3 17c2.2 0 2.2-3 4.5-3S9.7 17 12 17s2.2-3 4.5-3S18.8 17 21 17"/>',
  rings: '<circle cx="9" cy="12" r="6"/><circle cx="15" cy="12" r="6"/>',
  anchor: '<circle cx="12" cy="5" r="2.4"/><path d="M12 7.4V21"/><path d="M5 13a7 7 0 0 0 14 0"/><path d="M5 13H3m18 0h-2"/>',
  sprout: '<path d="M12 20v-7"/><path d="M12 13c0-3-2.4-5.5-6-5.5 0 3.4 2.5 5.5 6 5.5Z"/><path d="M12 11c0-2.6 2.2-4.8 5.5-4.8 0 3-2.4 4.8-5.5 4.8Z"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5 5-2Z"/>',
  leaf: '<path d="M5 19c0-8 5-13 14-13 0 9-5 14-13 14"/><path d="M5 19c3-4 6-6 10-7"/>',
  chevron: '<path d="m6 9 6 6 6-6"/>',
  arrow: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  phone: '<path d="M6.5 3.5h3l1.5 4-2 1.5a11 11 0 0 0 4.5 4.5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16.5 16.5 0 0 1 4.5 5.7 2 2 0 0 1 6.5 3.5Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  map: '<path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/>',
  parking: '<rect x="3.5" y="3.5" width="17" height="17" rx="4"/><path d="M9.5 17V7h3.2a3 3 0 0 1 0 6H9.5"/>',
  video: '<rect x="3" y="6" width="12" height="12" rx="2.5"/><path d="m15 10 6-3v10l-6-3"/>',
  heart: '<path d="M12 20s-7-4.3-7-9.5A4.5 4.5 0 0 1 12 7a4.5 4.5 0 0 1 7 3.5C19 15.7 12 20 12 20Z"/>',
  check: '<path d="m4.5 12.5 5 5 10-11"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  close: '<path d="m6 6 12 12M18 6 6 18"/>',
  instagram: '<rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="3.8"/><circle cx="17" cy="7" r="1.1" fill="currentColor" stroke="none"/>',
  facebook: '<path d="M14.5 8.5V6.8c0-.9.4-1.3 1.4-1.3H17V2.5h-2.4c-2.6 0-3.8 1.5-3.8 3.9v2.1H9v3h1.8V21.5h3.7V11.5H17l.5-3h-3Z"/>',
  linkedin: '<rect x="3.5" y="3.5" width="17" height="17" rx="3"/><path d="M8 10v7"/><circle cx="8" cy="7" r="1.1" fill="currentColor" stroke="none"/><path d="M12 17v-4a2.5 2.5 0 0 1 5 0v4"/><path d="M12 17v-7"/>',
};

const d = paths[name] ?? "";
const labelled = Boolean(title);
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  style={color ? `color:${color}` : undefined}
  role={labelled ? "img" : undefined}
  aria-hidden={labelled ? undefined : "true"}
  aria-label={title}
  set:html={(labelled ? `<title>${title}</title>` : "") + d}
/>
